# =====================================================================
#  MODELO de variaveis de ambiente (SEM segredos — seguro pra commitar).
#  Os valores REAIS ficam no .env.local (ignorado pelo git) e na Vercel.
# =====================================================================

# ---------- Stripe ----------
# Stripe > Developers > API keys > "Secret key" (modo LIVE no lancamento)
STRIPE_SECRET_KEY=sk_live_xxxxxxxxxxxxxxxxxxxx
# Gerado ao registrar o webhook (Stripe > Developers > Webhooks > Add endpoint)
STRIPE_WEBHOOK_SECRET=whsec_xxxxxxxxxxxxxxxxxxxx

# ---------- INFIZAP ----------
INFIZAP_API_BASE=https://appbk.infizap.com
INFIZAP_ADMIN_EMAIL=seu-email-admin@infizap.com.br
INFIZAP_ADMIN_PASSWORD=sua-senha-admin

# ---------- Email de boas-vindas (SMTP Hostinger) ----------
SMTP_HOST=smtp.hostinger.com
SMTP_PORT=465
SMTP_USER=no-reply@infizap.com
SMTP_PASS=senha-da-caixa-no-reply
MAIL_FROM=INFIZAP <no-reply@infizap.com>
APP_LOGIN_URL=https://app.infizap.com/login
